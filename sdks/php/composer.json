{
    "name": "philiprehberger/webhook-relay-client",
    "description": "PHP SDK + signature verifier for the Webhook Relay API.",
    "type": "library",
    "license": "MIT",
    "keywords": ["webhook", "webhook-relay", "hmac", "signature", "api-client"],
    "homepage": "https://webhook-relay.dcsuniverse.com",
    "support": {
        "source": "https://github.com/philiprehberger/webhook-relay/tree/main/sdks/php"
    },
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "WebhookRelay\\Client\\": ["src/", "generated/lib/"]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebhookRelay\\Client\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
