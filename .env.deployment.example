# Copy to .env.deployment (gitignored) and fill in values.
# Used by scripts/deploy/deploy.cjs to push releases to the EC2 host.

SERVER_HOST=54.190.150.0
SERVER_USERNAME=ubuntu
SERVER_PRIVATE_KEY=/home/ubuntu/.ssh/ps4_new

# Defaults to /var/www/webhook-relay if unset.
SERVER_BASE_PATH=/var/www/webhook-relay

# How many prior releases to keep on the server for rollback.
RELEASES_TO_KEEP=5

# Optional: Sentry release tracking. Leave unset to skip.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
